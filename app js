// Function to verify everything is linked
console.log("Script loaded and running.");

document.addEventListener('DOMContentLoaded', () => {
    const fileInput = document.getElementById('excelInput');

    // Triggered when you select a file
    fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;

        console.log("File selected: ", file.name);

        const reader = new FileReader();
        reader.onload = function(evt) {
            try {
                const data = evt.target.result;
                const workbook = XLSX.read(data, { type: 'binary' });
                const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                
                // Convert Excel to JSON data
                const jsonData = XLSX.utils.sheet_to_json(firstSheet);
                
                if (jsonData.length > 0) {
                    processData(jsonData); // This is your function that handles the marks
                    alert("Upload successful! Found " + jsonData.length + " students.");
                }
            } catch (err) {
                console.error("Error reading file:", err);
                alert("Could not read Excel file. Make sure it's a valid .xlsx file.");
            }
        };
        reader.readAsBinaryString(file);
    });
});

    
