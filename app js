// Verification that the script is running
console.log("System Initialized...");

document.addEventListener('DOMContentLoaded', () => {
    const fileInput = document.getElementById('excelInput');
    
    if (!fileInput) {
        console.error("Critical Error: excelInput element not found in HTML!");
        return;
    }

    fileInput.addEventListener('change', function(e) {
        console.log("File detected!"); // If this doesn't show in F12 console, the event listener failed
        
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();

        reader.onload = (evt) => {
            try {
                const data = evt.target.result;
                // Use array type for better compatibility
                const workbook = XLSX.read(data, { type: 'binary' });
                const sheetName = workbook.SheetNames[0];
                const sheet = workbook.Sheets[sheetName];
                
                const rawData = XLSX.utils.sheet_to_json(sheet);
                console.log("Extracted Data:", rawData);

                if (rawData.length === 0) {
                    alert("The Excel file seems to be empty.");
                    return;
                }

                processData(rawData);
                alert("Data Uploaded Successfully!");
            } catch (err) {
                console.error("Excel Parsing Error:", err);
                alert("Failed to read Excel. Ensure it is a valid .xlsx file.");
            }
        };

        reader.onerror = (ex) => {
            console.error("FileReader Error:", ex);
        };

        reader.readAsBinaryString(file);
    });
});

